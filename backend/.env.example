# Copy to .env and adjust.
# Postgres (default; start it with `docker compose up -d db` from the repo root):
DATABASE_URL=postgresql+psycopg2://crm:crm@localhost:5432/crm
# Quick start without Postgres:
# DATABASE_URL=sqlite:///./dev.db

SECRET_KEY=change-me-in-production
TOKEN_TTL_HOURS=12

# --- Outbound messaging (optional) -----------------------------------------
# Without these, the portal uses one-click wa.me / mailto: links: the message
# is pre-filled and sent from YOUR WhatsApp (+244931405768 — stay logged into
# WhatsApp Web with it) or your mail client, and is still logged in the CRM.
#
# WhatsApp Business Cloud API (Meta): register your number at
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# then the portal sends directly, no click needed.
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
#
# SMTP for direct email sending (e.g. Gmail app password: smtp.gmail.com:587)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
